# Backend Environment Variables Example File
# Rename this file to .env and populate with actual credentials before running

# Application Port
PORT=5000

# MongoDB Connection String
# Local example: mongodb://127.0.0.1:27017/ruet-obe
# Production example (Atlas): mongodb+srv://<username>:<password>@cluster.mongodb.net/ruet-obe
MONGO_URI=mongodb://127.0.0.1:27017/ruet-obe

# Firebase Admin SDK Configuration
# For production, define either the base64 encoded service account JSON 
# OR use the project ID with GCP Application Default Credentials
# FIREBASE_SERVICE_ACCOUNT=base64_encoded_json_string_here
# FIREBASE_PROJECT_ID=your-firebase-project-id

# ALLOWED_ORIGINS (comma-separated origins for CORS)
# Production example: https://obe-webapp-demo.netlify.app
ALLOWED_ORIGINS=https://obe-webapp-demo.netlify.app,http://localhost:5173,http://localhost:5174
